  "stage_one_confirmation_design": {
    "title": "1단계 점검확정 → 6단계 자동 재계산 설계",
    "db_solution": "방안A: inspection_plan_items에 step1~6_date 컬럼 추가",
    "new_server_actions": [
      {
        "name": "confirmPlanItemStageOneAction",
        "params": [
          "planItemId: string",
          "confirmedDate: Date"
        ],
        "steps": [
          "inspection_plan_items.scheduled_date = confirmedDate, status = 'confirmed'",
          "6단계 날짜 계산: step1~4(영업일), step5(절대일+10), step6(영업일)",
          "step1~6_date 컬럼 UPDATE",
          "점검이력 INSERT (1단계 점검일자 확정 기록)",
          "revalidatePath /inspection-plans, /inspections/calendar"
        ]
      },
      {
        "name": "resetPlanItemsOnUseApprovalDateChange",
        "params": [
          "customerId: string",
          "newUseApprovalDate: Date"
        ],
        "steps": [
          "customers.use_approval_date 업데이트",
          "해당 고객 plan_items WHERE status IN ('planned','confirmed') 조회",
          "각 plan_item: step1~6_date = NULL, scheduled_date 재계산, status = 'planned'",
          "점검이력 INSERT (사용승인일 변경 + 리셋 기록)",
          "revalidatePath 다수"
        ]
      }
    ],
    "recalculation_triggers": [
      {
        "event": "1단계 점검일자 최초 확정",
        "action": "step1~6_date 전체 계산 저장"
      },
      {
        "event": "1단계 점검일자 변경(재확정)",
        "action": "step1~6_date 전체 재계산"
      },
      {
        "event": "사용승인일 변경",
        "action": "plan_items → planned 리셋, step1~6 초기화"
      },
      {
        "event": "1단계 확정 취소",
        "action": "plan_items → planned 리셋, step1~6 초기화"
      }
    ]
  },
