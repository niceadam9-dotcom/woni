  "six_stage_workflow": {
    "base_date_field": "customers.use_approval_date",
    "trigger_date_field": "inspection_plan_items.scheduled_date (1단계 확정일)",
    "note": "Victory9: 기준일이 use_approval_date → scheduled_date (1단계 점검일자확정일)로 변경",
    "stages": [
      {
        "step_num": 1,
        "name_ko": "1단계: 점검일자확정",
        "base": "use_approval_date",
        "offset_value": 1,
        "is_working_days": true,
        "sidebar_link": "점검업무"
      },
      {
        "step_num": 2,
        "name_ko": "2단계: 배치확인서 보고서 작성",
        "base": "step1_due",
        "offset_value": 5,
        "is_working_days": true,
        "sidebar_link": null
      },
      {
        "step_num": 3,
        "name_ko": "3단계: 관계인 보고서 제출",
        "base": "step1_due",
        "offset_value": 10,
        "is_working_days": true,
        "sidebar_link": "보고서제출현황"
      },
      {
        "step_num": 4,
        "name_ko": "4단계: 소방서 보고서 제출 및 이행계획서 등록",
        "base": "step1_due",
        "offset_value": 15,
        "is_working_days": true,
        "sidebar_link": "이행계획서등록"
      },
      {
        "step_num": 5,
        "name_ko": "5단계: 소방보수 완료",
        "base": "step4_due",
        "offset_value": 10,
        "is_working_days": false,
        "note": "절대일 (주말/공휴일 포함 카운트)",
        "sidebar_link": null
      },
      {
        "step_num": 6,
        "name_ko": "6단계: 이행완료보고서 제출",
        "base": "step5_due",
        "offset_value": 10,
        "is_working_days": true,
        "sidebar_link": "이행계획제출현황"
      }
    ],
