# 승진소방 ERP — sjfire.co.kr 리버스 프록시 (HTTPS 자동)
# Caddy가 Let's Encrypt 인증서를 자동 발급·갱신한다.
# 전제: 도메인 DNS A 레코드(sjfire.co.kr, www.sjfire.co.kr)가 이 서버 공인 IP를 가리킬 것.

sjfire.co.kr {
	reverse_proxy app:3000
	encode gzip

	header {
		# next.config.ts의 보안 헤더와 별개로 전송 계층 보강
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
	}
}

www.sjfire.co.kr {
	redir https://sjfire.co.kr{uri} permanent
}

# 스테이징 — 별도 체크아웃(/home/ubuntu/woni-staging, staging 브랜치) 컨테이너로 프록시
# DNS A 레코드(staging.sjfire.co.kr → 이 서버 IP) 추가 후 인증서 자동 발급됨.
# 검색엔진 노출 차단 헤더 포함. 스테이징 컨테이너가 내려가 있으면 502.
staging.sjfire.co.kr {
	reverse_proxy erp-staging-app:3000
	encode gzip

	header {
		X-Robots-Tag "noindex, nofollow"
	}
}
