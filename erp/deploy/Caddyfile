# 승진소방 ERP — sjfire.co.kr 리버스 프록시 (HTTPS 자동)
# Caddy가 Let's Encrypt 인증서를 자동 발급·갱신한다.
# 전제: 도메인 DNS A 레코드(sjfire.co.kr, www.sjfire.co.kr)가 이 서버 공인 IP를 가리킬 것.

sjfire.co.kr {
	reverse_proxy app:3000
	encode gzip

	header {
		# next.config.ts의 보안 헤더와 별개로 전송 계층 보강
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
	}
}

www.sjfire.co.kr {
	redir https://sjfire.co.kr{uri} permanent
}
