# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# supabase CLI
supabase/.temp/

# typescript
*.tsbuildinfo
next-env.d.ts

# 테스트 데이터 정리 백업 (개인정보 포함 — 커밋 금지)
scripts/backup/

# 브라우저 테스트 스크린샷 (로컬 검증용)
.test-shots/
.verify-092/

# python 캐시
__pycache__/
