{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "TaskUpdate",
        "hooks": [
          {
            "type": "command",
            "command": "node f:/AI/ERP/scripts/sync-checklist.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node f:/AI/ERP/scripts/sync-checklist.js"
          }
        ]
      }
    ]
  }
}
