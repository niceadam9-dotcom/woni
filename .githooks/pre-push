#!/bin/sh
# 회귀 게이트(pre-push) — 빌드 실패면 push 차단, 데이터 불변식은 경고.
# 활성화: git config core.hooksPath .githooks   (저장소당 1회)
# 긴급 우회는 지양. 전체 테스트는 배포 전 `npm run test:all`.

echo "[pre-push] 빌드(타입체크) 검사…"
( cd erp && npm run build ) || { echo "❌ [pre-push] 빌드 실패 — push 중단"; exit 1; }

echo "[pre-push] 데이터 불변식 검사(경고, 비차단)…"
( cd erp && node scripts/check-data-invariants.mjs ) || echo "⚠ [pre-push] 불변식 위반 감지 — 배포 전 확인 권장(push는 허용)"

echo "✅ [pre-push] 게이트 통과"
exit 0
